# Slack internal app credentials.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Must match the Redirect URL configured in the Slack app.
BUDDY_SOS_SLACK_REDIRECT_URI=http://127.0.0.1:34267/oauth/slack/callback

# Optional escape hatch for local development or CI. Real user OAuth tokens
# should live in the OS keychain, not in env files.
SLACK_USER_TOKEN=

# Optional override while Slack scopes are being tuned.
BUDDY_SOS_SLACK_USER_SCOPES=users:read,users:read.email,channels:read,groups:read,im:read,mpim:read,channels:history,groups:history,im:history,mpim:history,search:read,chat:write,canvases:read,canvases:write
